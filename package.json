{
  "name": "scira-cli-harness",
  "version": "0.1.0",
  "description": "Flue-powered Scira-style research CLI harness with search, benchmarking, and optional Daytona sandboxing.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaidmukaddam/scira-cli-harness.git"
  },
  "bugs": {
    "url": "https://github.com/zaidmukaddam/scira-cli-harness/issues"
  },
  "homepage": "https://github.com/zaidmukaddam/scira-cli-harness#readme",
  "keywords": [
    "scira",
    "flue",
    "cli",
    "research",
    "parallel",
    "exa",
    "firecrawl",
    "benchmark"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "module": "src/cli.ts",
  "bin": {
    "scira-harness": "./dist/scira-harness.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target=node --outfile=dist/scira-harness.js",
    "build:flue": "flue build --target node --workspace .flue --output .",
    "run:flue": "flue run research --target node --id research-dev --workspace .flue --output .",
    "typecheck": "tsc --noEmit",
    "start": "bun run dist/scira-harness.js"
  },
  "dependencies": {
    "@daytonaio/sdk": "0.140.0",
    "@flue/cli": "^0.3.11",
    "@flue/sdk": "^0.3.11",
    "@mariozechner/pi-ai": "0.73.1",
    "@mendable/firecrawl-js": "^4.22.2",
    "dotenv": "^17.4.2",
    "exa-js": "^2.12.1",
    "parallel-web": "^0.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
