# Copy this file to .env.local and fill in the values you need.
#
# Optional: reuse env files from another checkout (e.g. a sibling Scira web app).
# Lowest precedence among files; cwd .env / .env.local still override these.
# SCIRA_PROJECT_ROOT=/absolute/path/to/parent/scira
#
# Minimum for source gathering: set at least one search provider key.
PARALLEL_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Minimum for synthesis: set the provider key for the --model you use.
# Example: --model openai/gpt-4.1-mini uses OPENAI_API_KEY.
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional: default model sweep for benchmark runs.
# BENCHMARK_MODELS=openai/gpt-4.1-mini,anthropic/claude-sonnet-4-6

# Optional: Daytona sandbox execution for --sandbox and the sandbox command.
DAYTONA_API_KEY=
DAYTONA_TARGET=us
# DAYTONA_SNAPSHOT_NAME=your-daytona-snapshot-name

# Optional: point the harness at one explicit env file.
# Shell environment variables still win over file values.
# SCIRA_ENV_FILE=/absolute/path/to/.env
